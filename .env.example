# 复制本文件为 .env，填入你自己的配置。
# 注意：纯电子发票 PDF 走精确解析，0 token，不需要任何 key；
#       只有图片/扫描件用 AI 兜底时才需要下面的配置。
#
# 本工具「模型无关」：任何 OpenAI 兼容 + 能读图（多模态/视觉）的接口都能用，改这三行即可。

# 你的 API Key
API_KEY=sk-你的key

# 接口地址（OpenAI 兼容端点）
# · 通义千问(百炼)：https://dashscope.aliyuncs.com/compatible-mode/v1
# · 智谱 GLM-4V   ：https://open.bigmodel.cn/api/paas/v4
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 视觉模型名（要选「能看图」的那种）
# · 千问：qwen-vl-max / qwen-vl-plus
# · 智谱：glm-4v
VL_MODEL=qwen-vl-max
